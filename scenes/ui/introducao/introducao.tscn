[sub_resource type="Shader" id="Shader_vinheta"]
code = "shader_type canvas_item;\n\nuniform float intensidade : hint_range(0.0, 1.0) = 0.72;\n\nvoid fragment() {\n\tvec2 centro = UV * 2.0 - 1.0;\n\tcentro.x *= 0.78;\n\tfloat borda = smoothstep(0.28, 1.12, dot(centro, centro));\n\tCOLOR = vec4(0.004, 0.003, 0.020, borda * intensidade);\n}\n"

