[node name="LabelAvisoPause" type="Label" parent="PauseRoot/AvisoPause"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.9, 0.62, 1)
theme_override_colors/font_outline_color = Color(0, 0, 0, 0.95)
theme_override_constants/outline_size = 3
theme_override_fonts/font = ExtResource("2_font")
theme_override_font_sizes/font_size = 24
text = "EM DESENVOLVIMENTO"
horizontal_alignment = 1
vertical_alignment = 1

[connection signal="pressed" from="PauseRoot/CentroPause/PainelPause/MargemPause/ConteudoPause/BtnContinuar" to="." method="_on_btn_continuar_pressed"]
[connection signal="pressed" from="PauseRoot/CentroPause/PainelPause/MargemPause/ConteudoPause/BtnOpcoes" to="." method="_on_btn_opcoes_pressed"]
[connection signal="pressed" from="PauseRoot/CentroPause/PainelPause/MargemPause/ConteudoPause/BtnDesistir" to="." method="_on_btn_desistir_pressed"]
[connection signal="pressed" from="PauseRoot/CentroPause/PainelPause/MargemPause/ConteudoPause/BtnSalvar" to="." method="_on_btn_salvar_pressed"]
[connection signal="pressed" from="PauseRoot/CentroPause/PainelPause/MargemPause/ConteudoPause/BtnSair" to="." method="_on_btn_sair_pressed"]
[connection signal="value_changed" from="PauseRoot/TelaOpcoesPause/Centro/PainelOpcoesPause/Margem/Conteudo/LinhaVolume/SliderVolumePause" to="." method="_on_slider_volume_value_changed"]
[connection signal="toggled" from="PauseRoot/TelaOpcoesPause/Centro/PainelOpcoesPause/Margem/Conteudo/CheckTelaCheiaPause" to="." method="_on_check_tela_cheia_toggled"]
[connection signal="pressed" from="PauseRoot/TelaOpcoesPause/Centro/PainelOpcoesPause/Margem/Conteudo/BtnVoltarOpcoesPause" to="." method="_fechar_opcoes"]
[connection signal="pressed" from="PauseRoot/TelaConfirmarDesistencia/Centro/PainelConfirmarDesistencia/Margem/Conteudo/Botoes/BtnCancelarDesistencia" to="." method="_fechar_confirmacao"]
[connection signal="pressed" from="PauseRoot/TelaConfirmarDesistencia/Centro/PainelConfirmarDesistencia/Margem/Conteudo/Botoes/BtnConfirmarDesistencia" to="." method="_on_btn_confirmar_desistencia_pressed"]
